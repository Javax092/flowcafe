generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  ATTENDANT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING
  CASH_IN
  CASH_OUT
  CLOSING
}

model Business {
  id        String   @id @default(cuid())
  name      String
  document  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  categories    Category[]
  products      Product[]
  sales         Sale[]
  cashSessions  CashSession[]
  cashMovements CashMovement[]
  auditLogs     AuditLog[]
}

model User {
  id           String     @id @default(cuid())
  businessId   String
  name         String
  email        String
  passwordHash String
  role         UserRole   @default(ATTENDANT)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  business      Business       @relation(fields: [businessId], references: [id])
  sales         Sale[]
  cashSessions  CashSession[]
  cashMovements CashMovement[]
  auditLogs     AuditLog[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
}

model Category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id])
  products Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Product {
  id          String        @id @default(cuid())
  businessId  String
  categoryId  String?
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  cost        Decimal?      @db.Decimal(10, 2)
  imageUrl    String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business  Business   @relation(fields: [businessId], references: [id])
  category  Category?  @relation(fields: [categoryId], references: [id])
  saleItems SaleItem[]

  @@index([businessId])
  @@index([categoryId])
  @@index([status])
}

model CashSession {
  id             String            @id @default(cuid())
  businessId     String
  openedByUserId String
  closedByUserId String?
  status         CashSessionStatus @default(OPEN)
  dailyDate      String
  openingAmount  Decimal           @db.Decimal(10, 2)
  closingAmount  Decimal?          @db.Decimal(10, 2)
  expectedAmount Decimal?          @db.Decimal(10, 2)
  difference     Decimal?          @db.Decimal(10, 2)
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  notes          String?

  business      Business       @relation(fields: [businessId], references: [id])
  openedByUser  User           @relation(fields: [openedByUserId], references: [id])
  sales         Sale[]
  cashMovements CashMovement[]

  @@index([businessId])
  @@index([dailyDate])
  @@index([status])
}

model CashMovement {
  id            String           @id @default(cuid())
  businessId    String
  cashSessionId String
  userId        String
  type          CashMovementType
  amount        Decimal          @db.Decimal(10, 2)
  reason        String?
  createdAt     DateTime         @default(now())

  business    Business    @relation(fields: [businessId], references: [id])
  cashSession CashSession @relation(fields: [cashSessionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([cashSessionId])
  @@index([type])
  @@index([createdAt])
}

model Sale {
  id            String      @id @default(cuid())
  businessId    String
  cashSessionId String
  userId        String
  status        SaleStatus  @default(COMPLETED)
  dailyDate     String
  subtotal      Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  notes         String?
  cancelReason  String?
  cancelledAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  business    Business    @relation(fields: [businessId], references: [id])
  cashSession CashSession @relation(fields: [cashSessionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  items       SaleItem[]
  payments    Payment[]

  @@index([businessId])
  @@index([cashSessionId])
  @@index([userId])
  @@index([dailyDate])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id                  String   @id @default(cuid())
  saleId              String
  productId           String?
  productNameSnapshot String
  unitPriceSnapshot   Decimal  @db.Decimal(10, 2)
  quantity            Int
  subtotal            Decimal  @db.Decimal(10, 2)
  observation         String?

  sale    Sale     @relation(fields: [saleId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(cuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([method])
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}
